# Azure deploy용 secrets 템플릿.
#
# 사용법:
#   1. cp .azure/secrets.env.example .azure/secrets.env
#   2. 각 값 채움
#   3. .azure/deploy-infra.ps1 실행
#
# .azure/secrets.env는 .gitignore에 등록됨 — commit 금지.

# Postgres 관리자 비밀번호 (≥12자, 대소문자/숫자/기호 포함)
POSTGRES_ADMIN_PASSWORD=ReplaceWithStrongPassword123!

# GitHub Container Registry PAT
#   - github.com/settings/tokens 에서 발급
#   - Scope: read:packages, write:packages
GHCR_TOKEN=ghp_replace_with_real_token

# Azure OpenAI (기존 .env에서 복사)
LLM_ENDPOINT=https://your-azure-openai.openai.azure.com/
LLM_API_KEY=
LLM_DEPLOYMENT=gpt-5

# 외부 데이터 소스 (기존 .env에서 복사, 미설정 시 빈 값)
DART_API_KEY=
FRED_API_KEY=
TAVILY_API_KEY=

# Auth
JWT_SECRET=replace-with-32-byte-random-string
ADMIN_PASSWORD=admin1234
