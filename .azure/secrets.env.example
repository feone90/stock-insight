# Azure 배포 전용 secrets — backend/.env에 없는 것만 여기에.
#
# LLM_ENDPOINT / LLM_API_KEY / LLM_DEPLOYMENT / LLM_MODEL / LLM_PROVIDER,
# DART_API_KEY / FRED_API_KEY / TAVILY_API_KEY,
# JWT_SECRET / ADMIN_EMAIL / ADMIN_PASSWORD / SEC_USER_AGENT
# 는 deploy-infra.ps1이 backend/.env에서 자동 로드합니다. 중복 입력 X.
#
# 사용법:
#   1. cp .azure/secrets.env.example .azure/secrets.env
#   2. 아래 2개 값 채움
#   3. .azure/deploy-infra.ps1 실행
#
# .azure/secrets.env는 .gitignore에 등록됨 — commit 안 됨.

# Postgres 관리자 비밀번호 (≥12자, 대소문자+숫자+기호)
POSTGRES_ADMIN_PASSWORD=

# GitHub Container Registry PAT
#   - https://github.com/settings/tokens → "Generate new token (classic)"
#   - Scope: read:packages + write:packages
#   - 생성 후 1번만 보임 — 바로 복사
GHCR_TOKEN=
