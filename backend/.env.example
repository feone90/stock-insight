# === DB ===
DATABASE_URL=postgresql+asyncpg://postgres:admin123!@localhost:5432/stockinsight?ssl=disable

# === 데이터 수집 API 키 ===
DART_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# === LLM ===
LLM_PROVIDER=azure_openai
LLM_ENDPOINT=
LLM_API_KEY=
LLM_DEPLOYMENT=
LLM_MODEL=

# === 스케줄러 ===
SCHEDULER_ENABLED=false
SCHEDULER_MORNING=08:00
SCHEDULER_EVENING=18:00
SCHEDULER_TIMEZONE=Asia/Seoul

# === 인증 ===
JWT_SECRET=change-me-in-production
ADMIN_EMAIL=admin@stockinsight.local
ADMIN_PASSWORD=admin1234

# === v2 analyst engine ===
# LLM model selection (Stage 1 research = cheap-tier, Stage 2 synthesize = premium)
ANALYST_RESEARCH_MODEL=gpt-5-mini
ANALYST_SYNTHESIZE_MODEL=gpt-5

# Web search provider — sign up at https://tavily.com (free tier: 1000 calls/month)
TAVILY_API_KEY=

# Cost guard — daily LLM budget cap and per-stock refresh cooldown
ANALYSIS_DAILY_BUDGET_USD=10
ANALYSIS_COOLDOWN_SECONDS=300

# Schedule (KR/US split — cron strings, server timezone = KST)
SCHEDULE_KR_MORNING=30 8 * * 1-5
SCHEDULE_KR_AFTERNOON=0 16 * * 1-5
SCHEDULE_US_EVENING=0 7 * * 1-5
SCHEDULE_US_NIGHT=30 22 * * 1-5

# === External data adapters (P1.5) ===
# SEC EDGAR identifies callers by User-Agent — required, not enforced by API key.
# Format: "<App name> <contact email>"   (https://www.sec.gov/os/accessing-edgar-data)
SEC_USER_AGENT=StockInsight family-use you@example.com

# === FRED (Federal Reserve Economic Data) ===
# 무료 (https://fred.stlouisfed.org/docs/api/api_key.html). VIX/US10Y/FedFunds/UNRATE 일일 sync.
FRED_API_KEY=

# === Finnhub free tier — US earnings calendar + analyst consensus ===
# 발급: https://finnhub.io/dashboard (이메일 가입만, 무료 60 req/min).
# 없으면 collector graceful skip → Earnings/AnalystRating 카드 섹션 자동 숨김.
FINNHUB_API_KEY=
